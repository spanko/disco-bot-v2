# =============================================================================
# Discovery Bot v2 — Environment Parameter File
# Copy this file:  cp template.env myenv.env
# Then fill in your values below.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# Short prefix for all resource names (lowercase, no hyphens, max 10 chars)
# Example: "acme", "contoso", "disco"
PREFIX=

# Environment suffix
# Allowed: dev, staging, prod
SUFFIX=dev

# Azure region for all resources
LOCATION=eastus2

# Your Azure AD Object ID (run: az ad signed-in-user show --query id -o tsv)
DEPLOYER_OBJECT_ID=

# Azure subscription ID (run: az account show --query id -o tsv)
SUBSCRIPTION_ID=

# ── Conversation Mode ────────────────────────────────────────────────────────

# lightweight = No Cosmos/Search/Blob (~$8.50/mo). Agent + Foundry only.
# standard   = Cosmos + Search + Blob (~$100/mo). Full knowledge extraction.
# full       = Standard + observability alerts + extended logging.
CONVERSATION_MODE=lightweight

# ── Auth Mode ────────────────────────────────────────────────────────────────

# none           = Open access (dev/demo only)
# magic_link     = Email-based token auth (requires JWT_SIGNING_KEY)
# invite_code    = Code-based auth (requires INVITE_CODES)
# entra_external = Azure AD External ID
AUTH_MODE=none

# ── Optional ─────────────────────────────────────────────────────────────────

# Model deployment name in Foundry (default: gpt-4o)
MODEL_DEPLOYMENT_NAME=gpt-4o

# Cosmos consistency level
# Allowed: Session, BoundedStaleness, Strong, ConsistentPrefix, Eventual
COSMOS_CONSISTENCY=Session

# Tags (JSON object)
TAGS='{"project":"discovery-bot-v2","managedBy":"deploy-scripts"}'

# Container image tag override (default: git SHA at build time)
# IMAGE_TAG=

# ── Auth-specific (only needed if AUTH_MODE is set) ──────────────────────────

# For magic_link auth: a 32+ char secret key
# Generate: openssl rand -base64 32
# JWT_SIGNING_KEY=

# For invite_code auth: comma-separated codes
# INVITE_CODES=CODE1:context1,CODE2:context2

# For entra_external auth:
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=

# ── Observability (only if CONVERSATION_MODE=full) ───────────────────────────

# Comma-separated email addresses for alert notifications
# ALERT_EMAILS=ops@example.com,team@example.com

# ── Resource Group ───────────────────────────────────────────────────────────

# Override the auto-generated resource group name
# Default: {PREFIX}-{SUFFIX}-rg
# RESOURCE_GROUP_NAME=
